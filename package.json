{
  "name": "pannes-historiques",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "scripts": {
    "deploy": "wrangler deploy",
    "deploy:dry-run": "wrangler deploy --dry-run",
    "cf:status": "wrangler containers list",
    "format": "biome format --write app/static",
    "lint": "biome lint app/static",
    "check": "biome check app/static",
    "audit:live-ui": "node scripts/maintenance/live-ui-audit.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:mobile": "playwright test --project=mobile-chromium"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@cloudflare/containers": "^0.3.3",
    "@playwright/test": "^1.56.1",
    "wrangler": "^4.87.0"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "maplibre-gl": "^5.24.0",
    "topojson-client": "^3.1.0",
    "topojson-server": "^3.0.1",
    "topojson-simplify": "^3.0.3"
  }
}
